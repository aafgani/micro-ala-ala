// Runs the built .dll when debugging
{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "web-app",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-web-client",
      "program": "${workspaceFolder}/apps/App.Web.Client/bin/Debug/net8.0/App.Web.Client.dll", // the entry point for the debugger
      "args": [],
      "cwd": "${workspaceFolder}/apps/App.Web.Client",
      "stopAtEntry": false,
      "console": "internalConsole"
    },
    {
      "name": "todo-api",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-todo-api",
      "program": "${workspaceFolder}/apps/App.Api.Todo/bin/Debug/net8.0/App.Api.Todo.dll",
      "args": [],
      "cwd": "${workspaceFolder}/apps/App.Api.Todo",
      "stopAtEntry": false,
      "console": "integratedTerminal"
    },
    {
      "name": "web-app (Docker)",
      "type": "docker",
      "request": "launch",
      "preLaunchTask": "build-web-client",
      "platform": "netCore",
      "dockerRun": {
        "containerName": "web-app-debug",
        "image": "web-app-debug-image",
        "dockerfile": "${workspaceFolder}/apps/App.Web.Client/Dockerfile",
        "context": "${workspaceFolder}/apps/App.Web.Client",
        "env": {
          "ASPNETCORE_ENVIRONMENT": "Development"
        },
        "ports": [
          {
            "containerPort": 5000,
            "hostPort": 5000
          }
        ],
        "volumeMappings": [
          {
            "containerPath": "/app",
            "hostPath": "${workspaceFolder}/apps/App.Web.Client"
          }
        ]
      },
      "cwd": "/app",
      "stopAtEntry": false
    }
  ],
  "compounds": [
    {
      "name": "Start API and Web Client",
      "configurations": ["todo-api", "web-app"]
    }
  ]
}
